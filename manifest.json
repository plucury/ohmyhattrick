{
  "manifest_version": 3,
  "name": "Oh My Hattrick",
  "description": "Compact player data display for Hattrick player list pages.",
  "version": "0.1.0",
  "content_scripts": [
    {
      "matches": [
        "https://*.hattrick.org/Club/Players*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
